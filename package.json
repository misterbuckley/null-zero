{
  "name": "null-zero",
  "version": "0.0.0",
  "private": true,
  "description": "A single-player, terminal-based, AI-driven roguelike.",
  "type": "module",
  "bin": {
    "null-zero": "./dist/main.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "doctor": "tsx src/doctor.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/main.js",
    "format": "biome format --write .",
    "lint": "biome check ."
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "neo-blessed": "^0.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
